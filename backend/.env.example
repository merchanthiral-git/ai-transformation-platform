# AI Transformation Platform — Backend Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (required for AI features)
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Database URL (defaults to SQLite for local dev)
# For PostgreSQL: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./app.db

# JWT Secret (auto-generated if not set, but set in production)
JWT_SECRET=change-me-in-production

# Resend Email API (optional — emails logged to console if not set)
# Sign up at: https://resend.com (free: 100 emails/day)
# Create API key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email sender (use onboarding@resend.dev for testing, your domain after verification)
SENDER_EMAIL=onboarding@resend.dev

# Admin notification email
ADMIN_EMAIL=merchanthiral@gmail.com

# App URL (used in email links)
APP_URL=http://localhost:3000
