# AI Transformation Platform — Environment Variables

# Required: Anthropic Claude API key for all AI features
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_key_here

# ── Database ──
# Defaults to SQLite (./app.db) if not set — no setup needed for local dev.
# For production, use PostgreSQL:
#   DATABASE_URL=postgresql://user:password@host:5432/ai_platform
#
# Railway/Render/Supabase provide this automatically.
# Note: postgres:// URLs are auto-converted to postgresql:// (Railway quirk).
#
# After setting DATABASE_URL, run migrations:
#   cd backend && source ../venv/bin/activate && alembic upgrade head
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_platform

# ── File Storage (Cloudflare R2) ──
# Defaults to local filesystem (data/uploads/) if not set.
# For production, configure Cloudflare R2:
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_BUCKET=your-bucket-name
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Optional: Auth (auto-generated if not set)
JWT_SECRET=your_secret_key_here

# Optional: Email notifications via Resend
RESEND_API_KEY=your_resend_api_key_here
